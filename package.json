{
  "name": "olsen-mono",
  "description": "A monorepo for exploring stuff",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "keywords": [
    "css-to-dts",
    "eslint",
    "hono",
    "htmx",
    "lightningcss",
    "monorepo",
    "node 26",
    "pnpm",
    "prettier",
    "stylelint",
    "tsdown",
    "turborepo",
    "typescript 6",
    "vite",
    "vitest"
  ],
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=26.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "pnpm": ">= 11.0.0"
  },
  "author": "Leif Olsen",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olsen-mono/olsen-mono.git"
  },
  "bugs": {
    "url": "https://github.com/olsen-mono/olsen-mono/issues"
  },
  "homepage": "https://github.com/olsen-mono/olsen-mono#readme",
  "scripts": {
    "build": "turbo run compile typecheck test && pnpm lint",
    "changeset": "changeset",
    "ci": "pnpm build",
    "clean": "shx rm -rf .turbo \"**/.turbo\" node_modules/.cache \"**/node_modules/.vite\" \"**/.tsbuildinfo\" && pnpm install",
    "compile": "turbo run compile",
    "find-caches": "shx ls -d .turbo \"**/.turbo\" \"**/node_modules/.vite\" \"node_modules/.cache\" \"**/.tsbuildinfo\"",
    "fix-code-prettier": "prettier . --ignore-path .prettierignore --write",
    "fix-code-style": "stylelint \"packages/**/*.css\" \"apps/**/*.css\" --fix",
    "fix-code-ts": "eslint . --fix",
    "lint": "pnpm lint:ts && pnpm lint:style && pnpm lint:prettier",
    "lint:prettier": "prettier . --check --ignore-path .prettierignore",
    "lint:style": "stylelint \"packages/**/*.css\" \"apps/**/*.css\" --allow-empty-input",
    "lint:ts": "eslint . --max-warnings 10",
    "lint-inspect": "pnpm dlx @eslint/config-inspector@latest",
    "prepare": "turbo run compile --filter=@olsen-mono/css-to-dts",
    "release": "changeset publish",
    "show-tsconfig": "tsc --showConfig",
    "test": "turbo run test",
    "test-watch": "vitest",
    "typecheck": "turbo run typecheck",
    "version-packages": "changeset version && pnpm install",
    "dev-htmx": "turbo run copy-deps css-to-dts && pnpm --filter=./apps/hono-htmx... dev",
    "build-htmx": "turbo run compile --filter=./apps/hono-htmx..."
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint/compat": "2.1.0",
    "@eslint/config-helpers": "0.6.0",
    "@eslint/js": "10.0.1",
    "@olsen-mono/tooling": "workspace:*",
    "@tsdown/css": "0.22.2",
    "@turbo/gen": "2.9.14",
    "@types/css-modules": "1.0.5",
    "@types/node": "catalog:",
    "copyfiles": "2.4.1",
    "cross-env": "10.1.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.6.0",
    "happy-dom": "20.9.0",
    "jiti": "2.7.0",
    "lightningcss": "1.32.0",
    "lightningcss-cli": "1.32.0",
    "open-props": "1.7.23",
    "prettier": "3.8.3",
    "shx": "0.4.0",
    "stylelint": "17.12.0",
    "stylelint-config-css-modules": "4.6.0",
    "stylelint-config-standard": "40.0.0",
    "tsdown": "^0.22.0",
    "turbo": "2.9.14",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  }
}
