{
  "name": "olsen-mono",
  "description": "A monorepo for exploring stuff",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "keywords": [
    "typescript 6",
    "node 26",
    "eslint",
    "stylelint",
    "prettier",
    "pnpm",
    "monorepo",
    "tsdown",
    "turborepo",
    "css-to-dts",
    "vitest",
    "vite",
    "hono",
    "htmx"
  ],
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=26.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "pnpm": ">= 11.0.0"
  },
  "author": "Leif Olsen",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olsen-mono/olsen-mono.git"
  },
  "bugs": {
    "url": "https://github.com/olsen-mono/olsen-mono/issues"
  },
  "homepage": "https://github.com/olsen-mono/olsen-mono#readme",
  "scripts": {
    "build": "pnpm lint && turbo typecheck test compile",
    "changeset": "changeset",
    "ci": "pnpm build",
    "clean": "pnpm --recursive --if-present clean",
    "compile": "turbo compile",
    "dev": "turbo run dev",
    "fix-code-prettier": "prettier . --ignore-path .prettierignore --write",
    "fix-code-style": "stylelint packages/**/*.css --fix",
    "fix-code-ts": "eslint . --fix",
    "lint": "pnpm \"/^lint:.*/\"",
    "lint:prettier": "prettier . --check --ignore-path .prettierignore",
    "lint:style": "stylelint packages/**/*.css --allow-empty-input",
    "lint:ts": "eslint . --max-warnings 10",
    "lint-inspect": "pnpm dlx @eslint/config-inspector@latest",
    "prepare": "turbo run compile --filter=@olsen-mono/css-to-dts",
    "release": "changeset publish",
    "test": "turbo test",
    "test-watch": "vitest",
    "typecheck": "turbo typecheck",
    "typedoc": "typedoc && prettier \"./packages/README.md\" \"./packages/**/src.md\" --ignore-path .prettierignore --write",
    "version-packages": "changeset version && pnpm install",
    "dev-htmx": "pnpm --filter apps/hono-htmx run dev",
    "build-htmx": "pnpm turbo build --filter=./apps/hello-htmx...",
    "show-tsconfig": "tsc --showConfig"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint/compat": "2.0.5",
    "@eslint/js": "10.0.1",
    "@olsen-mono/tooling": "workspace:*",
    "@turbo/gen": "2.9.14",
    "@types/css-modules": "1.0.5",
    "@types/node": "catalog:",
    "cpy-cli": "7.0.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.6.0",
    "happy-dom": "20.9.0",
    "jiti": "2.6.1",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "stylelint": "17.10.0",
    "stylelint-config-css-modules": "4.6.0",
    "stylelint-config-standard": "40.0.0",
    "tsdown": "^0.22.0",
    "turbo": "2.9.14",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vitest": "4.1.5"
  }
}
