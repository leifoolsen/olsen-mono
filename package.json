{
  "name": "olsen-mono",
  "description": "A monorepo for exploring stuff",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "keywords": [
    "astro",
    "biome",
    "css-to-dts",
    "hono",
    "htmx",
    "lightningcss",
    "monorepo",
    "node 26",
    "pnpm",
    "tsdown",
    "turborepo",
    "typescript 6",
    "vite",
    "vitest"
  ],
  "packageManager": "pnpm@11.10.0",
  "browserslist": [
    "> 0.25%",
    "not dead"
  ],
  "engines": {
    "node": ">=26.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "pnpm": ">= 11.0.0"
  },
  "author": "Leif Olsen",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olsen-mono/olsen-mono.git"
  },
  "bugs": {
    "url": "https://github.com/olsen-mono/olsen-mono/issues"
  },
  "homepage": "https://github.com/olsen-mono/olsen-mono#readme",
  "scripts": {
    "build": "turbo run compile typecheck test && pnpm lint",
    "changeset": "changeset",
    "ci": "pnpm build",
    "clean": "shx rm -rf .turbo \"**/.turbo\" node_modules/.cache \"**/node_modules/.vite\" \"**/.tsbuildinfo\" && pnpm install",
    "compile": "turbo run compile",
    "find-caches": "shx ls -d .turbo \"**/.turbo\" \"**/node_modules/.vite\" \"node_modules/.cache\" \"**/.tsbuildinfo\"",
    "lint": "biome check .",
    "lint-fix": "biome check --write .",
    "prepare": "pnpm --filter=@olsen-mono/css-to-dts run compile",
    "release": "changeset publish",
    "show-tsconfig": "tsc --showConfig",
    "test": "turbo run test",
    "test-watch": "vitest",
    "typecheck": "turbo run typecheck",
    "version-packages": "changeset version && pnpm install --ignore-scripts",
    "dev-htmx": "turbo run copy-deps css-to-dts && pnpm --filter=./apps/hono-htmx... dev",
    "build-htmx": "turbo run compile --filter=./apps/hono-htmx...",
    "dev-astro": "pnpm --filter=./apps/astro-htmx... dev"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@changesets/cli": "2.31.0",
    "@olsen-mono/tooling": "workspace:*",
    "@tsdown/css": "0.22.2",
    "@turbo/gen": "2.9.18",
    "@types/css-modules": "1.0.5",
    "@types/node": "catalog:",
    "copyfiles": "2.4.1",
    "cross-env": "10.1.0",
    "globals": "17.6.0",
    "happy-dom": "20.10.3",
    "jiti": "2.7.0",
    "lightningcss": "1.32.0",
    "lightningcss-cli": "1.32.0",
    "open-props": "1.7.23",
    "shx": "0.4.0",
    "tsdown": "^0.22.2",
    "turbo": "2.10.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
