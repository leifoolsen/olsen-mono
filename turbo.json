{
  "$schema": "https://turbo.build",
  "globalDependencies": [".gitignore", ".prettierignore", "tsconfig.json"],
  "tasks": {
    "compile": {
      "dependsOn": ["^compile"],
      "outputs": ["lib/**", "dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^compile"],
      "cache": true,
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json"]
    },
    "test": {
      "dependsOn": ["^compile"],
      "cache": true,
      "inputs": ["src/**/*.ts", "test/**/*.ts"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
