{
  "$schema": "https://turbo.build",
  "futureFlags": {
    "watchUsingTaskInputs": true
  },
  "globalDependencies": [".gitignore", ".prettierignore", "tsconfig.json"],
  "tasks": {
    "css-to-dts": {
      "dependsOn": ["^compile"],
      "cache": true,
      "inputs": ["src/**/*.css"],
      "outputs": ["src/**/*.css.d.ts", "dist/**/*.css.d.ts"]
    },
    "compile": {
      "dependsOn": ["^compile", "css-to-dts"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["css-to-dts", "^compile"],
      "cache": true,
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json"]
    },
    "test": {
      "dependsOn": ["^compile"],
      "cache": true,
      "inputs": ["src/**/*.ts", "test/**/*.ts"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": []
    }
  }
}
