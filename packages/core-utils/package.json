{
  "name": "@olsen-mono/core-utils",
  "description": "Core Utils",
  "version": "0.0.0",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    },
    "./source": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "keywords": [],
  "author": "leif.o.olsen@gmail.com",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "/src",
    "/lib"
  ],
  "scripts": {
    "compile": "tsup --silent",
    "dev": "tsup --watch",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:prettier": "prettier . --check --ignore-path ../../.prettierignore",
    "lint:style": "stylelint \"src/**/*.css\" --allow-empty-input",
    "lint:ts": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@olsen-mono/tooling": "workspace:*"
  }
}
