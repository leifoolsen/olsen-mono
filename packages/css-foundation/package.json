{
  "name": "@olsen-mono/css-foundation",
  "description": "CSS Foundation",
  "version": "0.0.6",
  "private": true,
  "type": "module",
  "main": "./dist/main.css",
  "style": "./src/main.css",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./main.css": {
      "development": "./src/main.css",
      "types": "./src/main.css.d.ts",
      "default": "./dist/main.css"
    },
    "./colors.css": {
      "development": "./src/colors.css",
      "types": "./src/colors.css.d.ts",
      "default": "./dist/colors.css"
    },
    "./font-stacks.css": {
      "development": "./src/font-stacks.css",
      "types": "./src/font-stacks.css.d.ts",
      "default": "./dist/font-stacks.css"
    },
    "./reset.css": {
      "development": "./src/reset.css",
      "types": "./src/reset.css.d.ts",
      "default": "./dist/reset.css"
    },
    "./typesetting.css": {
      "development": "./src/typesetting.css",
      "types": "./src/typesetting.css.d.ts",
      "default": "./dist/typesetting.css"
    },
    "./typography.css": {
      "development": "./src/typography.css",
      "types": "./src/typography.css.d.ts",
      "default": "./dist/typography.css"
    },
    "./layouts.css": {
      "development": "./src/layouts.css",
      "types": "./src/layouts.css.d.ts",
      "default": "./dist/layouts.css"
    },
    "./package.json": "./package.json"
  },
  "keywords": [],
  "author": "leif.o.olsen@gmail.com",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/olsen-mono/olsen-mono.git",
    "directory": "packages/css-foundation"
  },
  "bugs": {
    "url": "https://github.com/olsen-mono/olsen-mono/issues"
  },
  "homepage": "https://github.com/olsen-mono/olsen-mono#readme",
  "scripts": {
    "clean": "shx rm -rf dist",
    "compile": "pnpm run clean && pnpm run css-to-dts && pnpm run copy-css-to-dist",
    "copy-css-to-dist": "copyfiles -u 1 \"src/**/*.{css,d.ts}\" dist",
    "compile-lightningcss": "lightningcss --error-recovery --output-dir ./dist ./src/*.css",
    "css-to-dts": "node ../css-to-dts/dist/css-to-dts.mjs src"
  },
  "devDependencies": {
    "@olsen-mono/css-to-dts": "workspace:*"
  }
}
