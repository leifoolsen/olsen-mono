{
  "name": "@olsen-mono/css-foundation",
  "description": "CSS Foundation",
  "version": "0.0.3",
  "private": true,
  "main": "./dist/reset.css",
  "style": "./dist/reset.css",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./reset.css": {
      "types": "./dist/reset.css.d.ts",
      "default": "./dist/reset.css"
    },
    "./typesetting.css": {
      "types": "./dist/typesetting.css.d.ts",
      "default": "./dist/typesetting.css"
    },
    "./package.json": "./package.json"
  },
  "keywords": [],
  "author": "leif.o.olsen@gmail.com",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/olsen-mono/olsen-mono.git",
    "directory": "packages/css-foundation"
  },
  "bugs": {
    "url": "https://github.com/olsen-mono/olsen-mono/issues"
  },
  "homepage": "https://github.com/olsen-mono/olsen-mono#readme",
  "scripts": {
    "clean": "rimraf lib",
    "precompile": "pnpm run clean && pnpm run css-to-dts",
    "compile": "cpy \"**/*.{css,css.d.ts}\" ../dist --cwd=src --parents",
    "css-to-dts": "pnpm exec css-to-dts src"
  },
  "devDependencies": {
    "@olsen-mono/css-to-dts": "workspace:*"
  }
}
