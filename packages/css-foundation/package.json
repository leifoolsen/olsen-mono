{
  "name": "@olsen-mono/css-foundation",
  "description": "CSS Foundation",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "main": "./dist/tokens.css",
  "style": "./src/tokens.css",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./tokens.css": {
      "development": "./src/tokens.css",
      "types": "./src/tokens.css.d.ts",
      "default": "./dist/tokens.css"
    },
    "./reset.css": {
      "development": "./src/reset.css",
      "types": "./src/reset.css.d.ts",
      "default": "./dist/reset.css"
    },
    "./typesetting.css": {
      "development": "./src/typesetting.css",
      "types": "./src/typesetting.css.d.ts",
      "default": "./dist/typesetting.css"
    },
    "./package.json": "./package.json"
  },
  "keywords": [],
  "author": "leif.o.olsen@gmail.com",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/olsen-mono/olsen-mono.git",
    "directory": "packages/css-foundation"
  },
  "bugs": {
    "url": "https://github.com/olsen-mono/olsen-mono/issues"
  },
  "homepage": "https://github.com/olsen-mono/olsen-mono#readme",
  "scripts": {
    "clean": "shx rm -rf dist",
    "compile": "pnpm run clean && pnpm run css-to-dts && pnpm run copy-deps",
    "copy-deps": "copyfiles -u 1 \"src/**/*.css\" \"src/**/*.d.ts\" dist",
    "css-to-dts": "npx css-to-dts src"
  },
  "devDependencies": {
    "@olsen-mono/css-to-dts": "workspace:*"
  }
}
