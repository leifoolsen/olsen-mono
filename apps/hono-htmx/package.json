{
  "name": "hono-htmx",
  "version": "0.0.12",
  "private": true,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/olsen-mono/olsen-mono.git",
    "directory": "apps/hello-htmx"
  },
  "bugs": {
    "url": "https://github.com/olsen-mono/olsen-mono/issues"
  },
  "homepage": "https://github.com/olsen-mono/olsen-mono#readme",
  "scripts": {
    "build": "vite build && tsdown && pnpm run copy-deps-prod",
    "compile": "pnpm run build",
    "copy-css": "copyfiles -f \"src/index.css\" dist/public/",
    "copy-deps": "copyfiles -f \"$(pnpm root)/htmx.org/dist/htmx.min.js\" public/js/",
    "copy-deps-prod": "copyfiles -f \"$(pnpm root)/htmx.org/dist/htmx.min.js\" dist/public/js/",
    "css-to-dts": "npx css-to-dts src",
    "dev": "vite",
    "start": "cross-env NODE_ENV=production node dist/server.js"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@olsen-mono/core-utils": "workspace:*",
    "@olsen-mono/css-foundation": "workspace:*",
    "hono": "catalog:",
    "htmx.org": "catalog:"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "catalog:",
    "@olsen-mono/css-to-dts": "workspace:*",
    "@types/node": "catalog:",
    "vite": "catalog:",
    "vite-plugin-full-reload": "1.2.0",
    "vite-plugin-live-reload": "3.1.0"
  }
}
